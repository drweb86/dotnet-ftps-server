<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="using:FtpsServerAvalonia"
        xmlns:controls="using:FtpsServerAvalonia.Controls"
        xmlns:res="using:FtpsServerAvalonia.Resources"
        x:Class="FtpsServerAvalonia.MainWindow"
        Title="{x:Static res:Strings.AppTitle}"
        MinWidth="1024"
        CanResize="True">

    <Window.Styles>
		<Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleTextPanel > TextBlock">
			<Setter Property="IsVisible" Value="{Binding !$parent[Window].ExtendClientAreaToDecorationsHint}" />
		</Style>
    </Window.Styles>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="4 4 0 0">
			<controls:MainMenuControl x:Name="MainMenu" StartStopClicked="MainMenu_StartStopClicked" />
		</StackPanel>

		<DockPanel Margin="0" Grid.Row="1">
			<controls:UpdateCheckExpanderView DockPanel.Dock="Top" />

			<!-- Main Content -->
			<Border Classes="Card">
				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition SharedSizeGroup="A" />
							<ColumnDefinition SharedSizeGroup="A" />
						</Grid.ColumnDefinitions>

						<controls:ServerConfigurationControl x:Name="ServerConfig"
															 Port="{Binding Port, Mode=TwoWay}"
															 MaxConnections="{Binding MaxConnections, Mode=TwoWay}"
															 CertificateSource="{Binding CertificateSource, Mode=TwoWay}"
															 CertificatePath="{Binding CertificatePath, Mode=TwoWay}"
															 CertificatePassword="{Binding CertificatePassword, Mode=TwoWay}"
															 Grid.Column="0" />

						<Border Background="{StaticResource TertiaryDarkBrush}"
								BorderBrush="{StaticResource AccentCyanBrush}"
								BorderThickness="1"
								CornerRadius="8"
								Padding="16"
								Margin="10,0,10,20"
								Grid.Column="1">
							<StackPanel>
								<Grid Margin="0,0,0,16">
									<TextBlock Text="{x:Static res:Strings.UsersTab}"
											   FontSize="18"
											   FontWeight="SemiBold"
											   Foreground="{StaticResource TextPrimaryBrush}"
											   HorizontalAlignment="Left"
											   VerticalAlignment="Center"/>
									<Button Content="{x:Static res:Strings.AddUserButton}"
											Classes="SecondaryButton"
											HorizontalAlignment="Right"
											Click="AddUser_Click"
											Padding="16,8"/>
								</Grid>

								<ItemsControl x:Name="UsersItemsControl">
									<ItemsControl.ItemTemplate>
										<DataTemplate>
											<controls:UserItemControl RemoveUserRequested="UserItemControl_RemoveUserRequested"/>
										</DataTemplate>
									</ItemsControl.ItemTemplate>
								</ItemsControl>
							</StackPanel>
						</Border>
					</Grid>
				</ScrollViewer>
			</Border>
		</DockPanel>
	</Grid>
</Window>
