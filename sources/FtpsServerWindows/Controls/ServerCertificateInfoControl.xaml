<UserControl x:Class="FtpsServerWindows.Controls.ServerCertificateInfoControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:res="clr-namespace:FtpsServerWindows.Resources"
             Visibility="Collapsed">

    <Border Background="{StaticResource TertiaryDarkBrush}"
            BorderBrush="#F59E0B"
            BorderThickness="1"
            CornerRadius="8"
            Padding="16"
            Margin="10,0,20,20">
        <StackPanel>

            <!-- Warning notice -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock Text="⚠ "
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#F59E0B"
                           VerticalAlignment="Center"/>
                <TextBlock Text="{x:Static res:Strings.CertNoticeTitle}"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="#F59E0B"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="{x:Static res:Strings.CertNoticeMessage}"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,12"/>

            <Separator Background="{StaticResource AccentCyanBrush}"
                       Opacity="0.4"
                       Margin="0,0,0,10"/>

            <!-- Certificate heading -->
            <TextBlock Text="{x:Static res:Strings.CertSectionTitle}"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,2"/>
            <TextBlock Text="-------------------------------------------"
                       
                       FontSize="11"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,6"/>

            <!-- Metadata table -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="68"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="{x:Static res:Strings.CertTypeLabel}"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2"/>
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="CertType"
                            FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="{x:Static res:Strings.CertSubjectLabel}"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2"/>
                <TextBlock Grid.Row="1" Grid.Column="1" x:Name="CertSubject"
                            FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="2" Grid.Column="0"
                           Text="{x:Static res:Strings.CertIssuerLabel}"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2"/>
                <TextBlock Grid.Row="2" Grid.Column="1" x:Name="CertIssuer"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2" TextWrapping="Wrap"/>

                <TextBlock Grid.Row="3" Grid.Column="0"
                           Text="{x:Static res:Strings.CertValidLabel}"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2"/>
                <TextBlock Grid.Row="3" Grid.Column="1" x:Name="CertValid"
                            FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2"/>

                <TextBlock Grid.Row="4" Grid.Column="0"
                           Text="{x:Static res:Strings.CertSerialLabel}"
                            FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,2"/>
                <TextBlock Grid.Row="4" Grid.Column="1" x:Name="CertSerial"
                            FontSize="12"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2" TextWrapping="Wrap"/>
            </Grid>

            <Separator Background="{StaticResource AccentCyanBrush}"
                       Opacity="0.4"
                       Margin="0,0,0,8"/>

            <!-- SHA-256 (prominent — most FTP clients show this) -->
            <TextBlock Text="{x:Static res:Strings.CertSha256Label}"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,4"/>
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="Sha256Text"
                         Grid.Column="0"
                         IsReadOnly="True"
                         
                         FontSize="13"
                         FontWeight="Bold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="CopySha256Button"
                        Content="{x:Static res:Strings.CertCopyButton}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,4"
                        Margin="8,0,0,0"
                        Click="CopySha256_Click"/>
            </Grid>

            <!-- SHA-1 -->
            <TextBlock Text="{x:Static res:Strings.CertSha1Label}"
                       FontSize="12"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,4"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox x:Name="Sha1Text"
                         Grid.Column="0"
                         IsReadOnly="True"
                         
                         FontSize="11"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"/>
                <Button Grid.Column="1"
                        x:Name="CopySha1Button"
                        Content="{x:Static res:Strings.CertCopyButton}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="10,4"
                        Margin="8,0,0,0"
                        Click="CopySha1_Click"/>
            </Grid>

        </StackPanel>
    </Border>
</UserControl>
